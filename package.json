{
  "name": "quarrel",
  "version": "0.0.0",
  "private": true,
  "description": "Quarrel AI (codename: Tarka) - the AI that won't let you lie to yourself.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify:env": "node scripts/verify-env.mjs",
    "smoke": "node scripts/smoke.mjs",
    "invite:beta": "node scripts/invite-beta.mjs",
    "report:retention": "node scripts/report-retention.mjs",
    "launch-check": "node scripts/launch-check.mjs",
    "evals": "promptfoo eval -c evals/personas.config.yaml",
    "emails:preview": "pnpm --filter @quarrel/emails preview",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "promptfoo": "^0.121.12",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
